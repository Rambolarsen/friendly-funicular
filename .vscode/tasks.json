{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Kill Dev Ports",
      "type": "shell",
      "command": "foreach ($port in @(3001, 5173)) { $p = (Get-NetTCPConnection -LocalPort $port -ErrorAction SilentlyContinue).OwningProcess; if ($p) { Stop-Process -Id $p -Force -ErrorAction SilentlyContinue; Write-Host \"Killed process on port $port\" } }; Write-Host 'Ports cleared'",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:.*localhost"
        }
      }
    },
    {
      "label": "npm: server",
      "type": "shell",
      "command": "npm run server",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "listening|started|running"
        }
      }
    },
    {
      "label": "Start Dev + Server",
      "dependsOn": ["Kill Dev Ports", "npm: dev", "npm: server"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
